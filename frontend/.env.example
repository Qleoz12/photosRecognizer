# Obligatorio si el API no está en 8732. No dejes la línea vacía: si está vacía, el front pediría HTML al propio Vite.
VITE_API_URL=http://localhost:8732

# Opcional: si en el API definiste PHOTOS_SHARE_CREATE_SECRET, poné el mismo valor aquí para generar enlaces /share.
# Quien solo abre un enlace compartido no necesita esto (no hace POST /create).
# VITE_PHOTOS_SHARE_CREATE_SECRET=

# (Solo API) Orígenes CORS extra, separados por coma — p. ej. URL pública de ngrok al compartir enlaces:
# CORS_EXTRA_ORIGINS=https://xxxx.ngrok-free.app

# Timeout por defecto en apiFetch (ms). Evita spinner eterno si el gateway/upstream no responde (default 300000 = 5 min).
# Operaciones muy largas (p. ej. búsqueda CLIP): subí el valor o pasá AbortSignal en la llamada concreta.
# VITE_API_FETCH_TIMEOUT_MS=600000

# UX / rendimiento (consola del navegador):
# VITE_LOG_API_TIMING=1   → loguea todas las llamadas apiFetch (además de las lentas).
# VITE_SLOW_API_MS=800    → umbral ms para info/warn en consola (default 1000).
# VITE_LOG_UX=1           → en build prod, también [ROUTE] al cambiar de página.

# (Solo servidor / API, no en Vite) PIN de 7 dígitos para la sección Archivo:
#   set ARCHIVE_PIN=1234567
#
# Peticiones HTTP lentas en logs/api.log y consola del API:
#   set SLOW_REQUEST_MS=500
